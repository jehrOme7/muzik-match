+// RESULT HELPERS — คำนวณคะแนนใหม่จากคำตอบทุกครั้ง
+// ป้องกันคะแนนซ้ำเมื่อผู้ใช้กดย้อนกลับ/แก้คำตอบ
+// ============================================================
+function calculateMoodScore(){
+  var score={dark:0,chill:0,energetic:0,emotional:0,indie:0};
+  for(var i=0;i<QUESTIONS.length;i++){
+    var ans=answers[i];
+    if(ans===undefined||ans===-1) continue;
+    var opt=QUESTIONS[i]&&QUESTIONS[i].opts&&QUESTIONS[i].opts[ans];
+    if(!opt||!opt.w) continue;
+    Object.keys(opt.w).forEach(function(k){score[k]=(score[k]||0)+opt.w[k];});
+  }
+  moodScore=score;
+  return score;
+}
